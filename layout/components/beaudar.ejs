<hr/>
<div id="beaudar-container">
    <div class="beaudar-theme-mask" aria-hidden="true"></div>
</div>
<script>
    (function() {
        const BEAUDAR_ORIGIN = 'https://beaudar.lipk.org';
        const SYNC_CLASS = 'theme-syncing';
        const SYNC_DURATION = 300;
        let pendingTheme = null;
        let hasInitialized = false;
        let transitionTimer = null;

        function getBeaudarTheme(theme) {
            return theme === 'dark' ? 'github-dark' : 'github-light';
        }

        function getContainer() {
            return document.getElementById('beaudar-container');
        }

        function getBeaudarFrame() {
            return document.querySelector('#beaudar-container iframe');
        }

        function animateContainerThemeSync() {
            const container = getContainer();
            if (!container || !hasInitialized || !getBeaudarFrame()) {
                return;
            }

            container.classList.add(SYNC_CLASS);
            if (transitionTimer) {
                window.clearTimeout(transitionTimer);
            }

            transitionTimer = window.setTimeout(function() {
                container.classList.remove(SYNC_CLASS);
            }, SYNC_DURATION);
        }

        function postThemeToBeaudar(theme) {
            const frame = getBeaudarFrame();
            if (!frame || !frame.contentWindow) {
                pendingTheme = theme;
                return false;
            }

            frame.contentWindow.postMessage({
                type: 'set-theme',
                theme: theme
            }, BEAUDAR_ORIGIN);
            pendingTheme = null;
            return true;
        }

        function bindFrameThemeSync(frame) {
            if (!frame || frame.dataset.themeSyncBound === 'true') {
                return;
            }

            frame.dataset.themeSyncBound = 'true';
            frame.addEventListener('load', function() {
                if (pendingTheme) {
                    postThemeToBeaudar(pendingTheme);
                }
            });
        }

        function loadBeaudar(theme) {
            if (hasInitialized) {
                postThemeToBeaudar(theme);
                return;
            }

            const container = getContainer();
            
            const script = document.createElement('script');
            script.src = 'https://beaudar.lipk.org/client.js';
            script.setAttribute('repo', '<%= theme.beaudar.repo %>');
            script.setAttribute('branch', '<%= theme.beaudar.branch %>');
            script.setAttribute('issue-term', 'url');
            script.setAttribute('issue-label', 'url');
            script.setAttribute('label', 'Beaudar');
            script.setAttribute('theme', theme);
            script.setAttribute('crossorigin', 'anonymous');
            script.setAttribute('input-position', 'top');
            script.async = true;

            pendingTheme = theme;
            hasInitialized = true;
            container.appendChild(script);
        }


        const containerObserver = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                mutation.addedNodes.forEach(function(node) {
                    if (node.tagName === 'IFRAME') {
                        bindFrameThemeSync(node);
                        if (pendingTheme) {
                            postThemeToBeaudar(pendingTheme);
                        }
                    }
                });
            });
        });

        containerObserver.observe(document.getElementById('beaudar-container'), {
            childList: true
        });

        function syncBeaudarTheme(themeName) {
            animateContainerThemeSync();
            loadBeaudar(getBeaudarTheme(themeName));
        }

        document.addEventListener('theme-change', function(event) {
            if (event && event.detail && event.detail.theme) {
                syncBeaudarTheme(event.detail.theme);
                return;
            }

            const isDark = document.documentElement.classList.contains('dark');
            syncBeaudarTheme(isDark ? 'dark' : 'light');
        });

        const initialFrame = getBeaudarFrame();
        if (initialFrame) {
            bindFrameThemeSync(initialFrame);
        }

        const isDark = document.documentElement.classList.contains('dark');
        syncBeaudarTheme(isDark ? 'dark' : 'light');
    })();
</script>
