<main>
    <h1>标签</h1>
    <ul class="tag-cloud">
        <% var tags = site.tags.sort('length', 'desc'); %>
        <% if (tags.length) { %>
            <% tags.forEach(function(tag) { %>
            <li>
                <a class="tag-link" href="<%- url_for(tag.path) %>">#<%= tag.name %></a>
                <span class="tag-count"><%= tag.length %></span>
            </li>
            <% }) %>
        <% } else { %>
            <li class="empty-tags">还没有标签，先在文章 Front Matter 添加 tags。</li>
        <% } %>
    </ul>
</main>
