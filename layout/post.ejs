<main>
    <% if (is_post()) { %>
    <h1>
        <%= page.title %>
    </h1>
    <% } %>
    <p>
        <i><time><%= date(page.date, 'YYYY/MM/DD HH:mm:ss' ) %></time></i>
    </p>
    <% if (page.tags && page.tags.length) { %>
    <p class="post-tags">
        <% page.tags.each(function(tag) { %>
        <a class="tag-link" href="<%- url_for(tag.path) %>">#<%= tag.name %></a>
        <% }) %>
    </p>
    <% } %>
    <div class="post-content">
        <%- page.content %>
    </div>
    <% if (theme.twikoo.enable || false) { %>
        <%- partial('components/twikoo') %>
    <% } %>
    <% if (theme.beaudar.enable || false) { %>
        <%- partial('components/beaudar') %>
    <% } %>
</main>
